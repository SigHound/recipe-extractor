# Copy to `backend/.env`. Used by:
#   - local `uvicorn` (reads this file from disk)
#   - Docker Compose `api` service (injects as container env; same keys, no duplicate file)
#
# `docker-compose.yml` still sets DATABASE_URL and CORS for the container — those win over
# DATABASE_URL here when using Docker. For local dev, set DATABASE_URL below.

DATABASE_URL=postgresql+psycopg://recipe:recipe@localhost:5432/recipe

# Nutrition (at least one provider). Free USDA key: https://fdc.nal.usda.gov/api-key-signup
USDA_API_KEY=

# Or Edamam (both required if using Edamam): https://developer.edamam.com/
EDAMAM_APP_ID=
EDAMAM_APP_KEY=
